        <!-- Main Content -->
        <main class="grow flex flex-col md:flex-row items-center justify-center p-8 max-w-7xl mx-auto w-full gap-12">
            <div class="max-w-md text-center md:text-left">
                <h1 class="text-6xl md:text-8xl font-black text-gray-200 mb-4 tracking-tighter">Booking page</h1>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">We can't seem to find the page you're
                    looking
                    for.</h2>
                <p class="text-lg text-gray-600 mb-10">
                    Error code: 404 <br>
                    Here are some helpful links instead:
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
                    <a href="/"
                        class="bg-rose-500 hover:bg-rose-600 text-white font-bold py-3 px-8 rounded-lg transition-colors shadow-md">
                        Home
                    </a>
                    <a href="#"
                        class="border border-gray-300 hover:bg-gray-50 text-gray-700 font-semibold py-3 px-8 rounded-lg transition-colors">
                        Help Centre
                    </a>
                </div>
            </div>

            <div class="w-full max-w-sm">
                <img src="https://images.unsplash.com/photo-1578328819058-b69f3a3b0f6b?auto=format&fit=crop&q=80&w=800"
