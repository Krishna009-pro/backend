<%- include('../partials/head') %>

    <body class="bg-white text-gray-900 font-sans selection:bg-rose-100 selection:text-rose-900">

        <!-- Header -->
        <header
            class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 px-6 py-4 flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-8">
                <a href="/" class="flex items-center gap-2 group transition-transform active:scale-95">
                    <svg class="w-8 h-8 text-rose-500 group-hover:rotate-12 transition-transform" viewBox="0 0 32 32"
                        fill="currentColor">
                        <path
                            d="M16 1c2.008 0 3.463.963 4.751 3.269l.533 1.025c1.954 3.83 6.114 12.54 7.1 14.836l.145.346c1.264 3.033.864 5.922-1.121 8.125-1.921 2.132-4.634 3.321-7.558 3.404L19.4 32l-.35-.001h-.1c-3.134 0-5.967-1.354-7.85-3.649-1.884 2.295-4.717 3.649-7.85 3.649h-.1l-.35-.001C2.851 31.916.138 30.727-1.783 28.595c-1.985-2.203-2.385-5.092-1.121-8.125l.145-.346c.986-2.296 5.146-11.006 7.1-14.836l.533-1.025C6.537 1.963 7.992 1 10 1c2.008 0 3.463.963 4.751 3.269L16 6.538l1.249-2.269C18.537 1.963 19.992 1 22 1zm0 2c-1.282 0-2.19.643-3.142 2.345L11.59 18.27l-.145.346c-1.085 2.604-.844 4.814.646 6.468C13.298 26.46 15.111 27.228 17.152 27.32l.248.003h.1c2.613 0 4.858-1.214 6.167-3.235l.133-.21c.882-1.464 1.147-3.087.726-4.904l-.071-.248c-.066-.217-.184-.55-.353-.984l-.173-.42c-.933-2.19-4.809-10.435-6.732-14.21l-.533-1.025C18.19 2.643 17.282 2 16 2zm-6 0c-1.282 0-2.19.643-3.142 2.345L5.59 18.27l-.145.346c-1.085 2.604-.844 4.814.646 6.468C7.298 26.46 9.111 27.228 11.152 27.32l.248.003h.1c2.613 0 4.858-1.214 6.167-3.235l.133-.21c.882-1.464 1.147-3.087.726-4.904l-.071-.248c-.066-.217-.184-.55-.353-.984l-.173-.42c-.933-2.19-4.809-10.435-6.732-14.21l-.533-1.025C10.19 2.643 9.282 2 8 2z" />
                    </svg>
                    <span class="text-rose-500 font-bold text-xl tracking-tighter">airbnb</span>
                </a>
                <%- include("../partials/nav") %>
            </div>

            <div class="flex items-center gap-4">
                <a href="/admin/add-home"
                    class="hidden sm:block text-sm font-semibold py-2.5 px-4 hover:bg-gray-100 rounded-full transition-all active:scale-95">
                    Airbnb your home
                </a>
                <button
                    class="p-2.5 border border-gray-200 rounded-full hover:shadow-md transition-shadow active:scale-95 bg-white">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9s2.015-9 4.5-9m0 18c-2.485 0-4.5-4.03-4.5-9s2.015-9 4.5-9" />
                    </svg>
                </button>
                <button
                    class="flex items-center gap-3 p-1.5 pl-4 border border-gray-200 rounded-full hover:shadow-md transition-shadow active:scale-95 bg-white">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <div
                        class="w-8 h-8 bg-gray-500 rounded-full flex items-center justify-center text-white ring-2 ring-white overflow-hidden">
                        <svg class="w-5 h-5 translate-y-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                                clip-rule="evenodd" />
                        </svg>
                    </div>
                </button>
            </div>
        </header>

        <main class="max-w-6xl mx-auto px-6 py-8">
            <!-- Property Header -->
            <div class="mb-6">
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                    <div>
                        <h1 class="text-2xl md:text-3xl font-bold mb-2">
                            <%= selectedHome.homename %>
                        </h1>
                        <div class="flex items-center flex-wrap gap-x-4 gap-y-2 text-sm font-medium">
                            <div class="flex items-center gap-1">
                                <svg class="w-4 h-4 text-rose-500 fill-current" viewBox="0 0 32 32">
                                    <path
                                        d="M16 2.5l4.3 8.7 9.6 1.4-6.9 6.8 1.6 9.6-8.6-4.5-8.6 4.5 1.6-9.6-6.9-6.8 9.6-1.4z" />
                                </svg>
                                <span>
                                    <%= selectedHome.Rating || '4.92' %>
                                </span>
                                <span class="text-gray-400">·</span>
                                <button class="underline hover:text-gray-600">48 reviews</button>
                            </div>
                            <div class="flex items-center gap-1">
                                <span
                                    class="bg-gray-100 px-2 py-0.5 rounded-sm text-xs font-bold uppercase tracking-wider">Superhost</span>
                            </div>
                            <button class="underline hover:text-gray-600 font-semibold">
                                <%= selectedHome.Location %>
                            </button>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <button
                            class="flex items-center gap-2 px-3 py-2 hover:bg-gray-100 rounded-lg transition-colors text-sm font-semibold underline underline-offset-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                            </svg>
                            Share
                        </button>
                        <%- include('partials/favBtn', { id: selectedHome._id }) %>
                    </div>
                </div>
            </div>

            <!-- Single Hero Image Layout -->
            <div class="relative group h-[400px] md:h-[500px] w-full overflow-hidden rounded-2xl mb-12 bg-gray-100">
                <img src="<%= selectedHome.imageUrl || '/images/img1.jpeg' %>" alt="<%= selectedHome.homename %>"
                    class="h-full w-full object-cover group-hover:scale-[1.02] transition-transform duration-700">
                <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>
                <button id="showPhotosBtn"
                    class="absolute bottom-6 right-8 bg-white/90 backdrop-blur border border-gray-900 px-4 py-2 rounded-lg text-sm font-bold shadow-lg flex items-center gap-2 hover:bg-white transition-all active:scale-95">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16m-7 6h7" />
                    </svg>
                    Show all photos
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-20">
                <!-- Content Section -->
                <div class="lg:col-span-2">
                    <div class="flex items-center justify-between pb-6 border-b border-gray-100">
                        <div>
                            <h2 class="text-xl font-semibold mb-1">Entire home hosted by Krishna Patil</h2>
                            <p class="text-sm text-gray-500 font-medium">6 guests · 3 bedrooms · 4 beds · 2.5 bathrooms
                            </p>
                        </div>
                        <div
                            class="w-14 h-14 bg-gray-900 rounded-full flex items-center justify-center text-white ring-4 ring-rose-50 overflow-hidden">
                            <img src="https://ui-avatars.com/api/?name=Krishna+Patil&background=E11D48&color=fff"
                                alt="Host" class="w-full h-full object-cover">
                        </div>
                    </div>

                    <div class="py-10 space-y-8 border-b border-gray-100">
                        <div class="flex gap-6">
                            <div class="pt-1"><svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg></div>
                            <div>
                                <h3 class="font-bold">Dedicated workspace</h3>
                                <p class="text-gray-500 text-sm">A private room with wifi that's well-suited for
                                    working.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <div class="pt-1"><svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z" />
                                </svg></div>
                            <div>
                                <h3 class="font-bold">Free cancellation for 48 hours</h3>
                                <p class="text-gray-500 text-sm">Get a full refund if you change your mind.</p>
                            </div>
                        </div>
                    </div>

                    <div class="py-10 border-b border-gray-100">
                        <div class="prose prose-sm max-w-none text-gray-600 leading-relaxed space-y-4">
                            <p>Relax with the whole family at this peaceful place to stay in <%= selectedHome.Location
                                    %>. Experience the perfect blend of modern luxury and traditional charm.</p>
                            <p>Our home features high ceilings, floor-to-ceiling windows, and a gourmet kitchen perfect
                                for families who love to cook. Located just minutes away from local attractions yet
                                tucked away in a quiet neighborhood.</p>
                            <button
                                class="flex items-center gap-1 font-bold text-gray-900 underline pointer-events-none">Show
                                more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 5l7 7-7 7" />
                                </svg></button>
                        </div>
                    </div>

                    <div class="py-10 border-b border-gray-100">
                        <h2 class="text-xl font-bold mb-6">What this place offers</h2>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="flex items-center gap-4 text-gray-700">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                <span>Mountain view</span>
                            </div>
                            <div class="flex items-center gap-4 text-gray-700">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071a11 11 0 0115.658 0M2.929 9.293a16.5 16.5 0 0121.742 0" />
                                </svg>
                                <span>Wifi</span>
                            </div>
                            <div class="flex items-center gap-4 text-gray-700">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>Carbon monoxide alarm</span>
                            </div>
                            <div class="flex items-center gap-4 text-gray-700">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                </svg>
                                <span>Security cameras on property</span>
                            </div>
                        </div>
                        <button
                            class="mt-8 border border-gray-900 font-bold px-6 py-3 rounded-lg hover:bg-gray-50 transition-colors active:scale-95">Show
                            all 32 amenities</button>
                    </div>
                </div>

                <!-- Booking Card -->
                <div class="relative">
                    <div class="sticky top-28 p-6 border border-gray-200 rounded-3xl shadow-xl space-y-6 bg-white">
                        <div class="flex items-center justify-between">
                            <div class="flex items-end gap-1">
                                <span class="text-2xl font-bold">₹<%= selectedHome.price %></span>
                                <span class="text-gray-500 text-sm mb-1 font-medium">night</span>
                            </div>
                            <div class="flex items-center gap-1 text-sm font-semibold">
                                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 32 32">
                                    <path
                                        d="M16 2.5l4.3 8.7 9.6 1.4-6.9 6.8 1.6 9.6-8.6-4.5-8.6 4.5 1.6-9.6-6.9-6.8 9.6-1.4z" />
                                </svg>
                                <span>
                                    <%= selectedHome.Rating || '4.92' %>
                                </span>
                                <span class="text-gray-400 font-normal">·</span>
                                <span class="text-gray-400 font-normal">48 reviews</span>
                            </div>
                        </div>

                        <div class="border border-gray-400 rounded-xl overflow-hidden divide-y divide-gray-400">
                            <div class="grid grid-cols-2 divide-x divide-gray-400">
                                <div class="px-3 py-2 space-y-0.5">
                                    <label class="text-[10px] font-extrabold uppercase tracking-tight">Check-in</label>
                                    <div class="text-sm">24/12/2024</div>
                                </div>
                                <div class="px-3 py-2 space-y-0.5">
                                    <label class="text-[10px] font-extrabold uppercase tracking-tight">Checkout</label>
                                    <div class="text-sm">29/12/2024</div>
                                </div>
                            </div>
                            <div class="px-3 py-2 space-y-0.5">
                                <label class="text-[10px] font-extrabold uppercase tracking-tight">Guests</label>
                                <div class="flex items-center justify-between text-sm">
                                    <span>2 guests</span>
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <button class="button w-full rounded-xl! py-3!" style="--clr: #E11D48;">
                            <span class="button-decor"></span>
                            <div class="button-content justify-center py-1">
                                <div class="button__icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none"
                                        viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </div>
                                <span class="button__text text-lg tracking-wide">Reserve Now</span>
                            </div>
                        </button>

                        <p class="text-center text-sm text-gray-500">You won't be charged yet</p>

                        <div class="space-y-3 pt-4 border-t border-gray-100 font-medium">
                            <div class="flex justify-between underline underline-offset-2">
                                <span>₹<%= selectedHome.price %> x 5 nights</span>
                                <span>₹<%= selectedHome.price * 5 %></span>
                            </div>
                            <div class="flex justify-between underline underline-offset-2">
                                <span>Cleaning fee</span>
                                <span>₹1,500</span>
                            </div>
                            <div class="flex justify-between underline underline-offset-2">
                                <span>Airbnb service fee</span>
                                <span>₹2,200</span>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-gray-100 flex justify-between font-bold text-lg">
                            <span>Total before taxes</span>
                            <span>₹<%= selectedHome.price * 5 + 3700 %></span>
                        </div>
                    </div>

                    <div class="mt-8 flex gap-4 p-4 border border-gray-200 rounded-xl items-center bg-rose-50/30">
                        <div class="text-rose-500">
                            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                                <path
                                    d="M12 2L1 21h22L12 2zm0 15a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm0-8a1 1 0 011 1v4a1 1 0 11-2 0v-4a1 1 0 011-1z" />
                            </svg>
                        </div>
                        <div class="text-xs leading-tight">
                            <span class="font-extrabold block mb-1">Low price for your dates</span>
                            <span class="text-gray-600">This is the lowest price for these dates recorded in the last 60
                                days.</span>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <footer class="mt-20 border-t border-gray-100 bg-gray-50 py-16 px-6">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
                <div class="space-y-4">
                    <h4 class="font-bold text-sm">Support</h4>
                    <ul class="text-sm text-gray-500 space-y-3">
                        <li class="hover:underline cursor-pointer">Help Centre</li>
                        <li class="hover:underline cursor-pointer">AirCover</li>
                        <li class="hover:underline cursor-pointer">Anti-discrimination</li>
                        <li class="hover:underline cursor-pointer">Disability support</li>
                        <li class="hover:underline cursor-pointer">Cancellation options</li>
                    </ul>
                </div>
                <div class="space-y-4">
                    <h4 class="font-bold text-sm">Hosting</h4>
                    <ul class="text-sm text-gray-500 space-y-3">
                        <li class="hover:underline cursor-pointer">Airbnb your home</li>
                        <li class="hover:underline cursor-pointer">AirCover for Hosts</li>
                        <li class="hover:underline cursor-pointer">Hosting resources</li>
                        <li class="hover:underline cursor-pointer">Community forum</li>
                        <li class="hover:underline cursor-pointer">Hosting responsibly</li>
                    </ul>
                </div>
            </div>
            <div
                class="max-w-7xl mx-auto mt-16 pt-8 border-t border-gray-200 flex flex-col md:flex-row justify-between items-center text-sm font-medium text-gray-500">
                <div class="flex flex-wrap gap-x-4 gap-y-2 mb-4 md:mb-0">
                    <span>© 2024 Airbnb, Inc.</span>
                    <span class="hover:underline cursor-pointer">Privacy</span>
                    <span class="hover:underline cursor-pointer">Terms</span>
                    <span class="hover:underline cursor-pointer">Sitemap</span>
                    <span class="hover:underline cursor-pointer">Company details</span>
                </div>
                <div class="flex items-center gap-6">
                    <button class="flex items-center gap-2 hover:underline">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        English (IN)
                    </button>
                    <button class="hover:underline font-bold">₹ INR</button>
                    <div class="flex gap-4">
                        <svg class="w-5 h-5 cursor-pointer hover:text-gray-900" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
                        </svg>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Photo Gallery Modal -->
        <div id="photoModal" class="fixed inset-0 z-[100] bg-white hidden overflow-y-auto">
            <div
                class="sticky top-0 bg-white/80 backdrop-blur-md px-6 py-4 flex items-center justify-between border-b border-gray-100">
                <button id="closePhotosBtn"
                    class="p-2 hover:bg-gray-100 rounded-full transition-colors active:scale-95">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

            </div>

            <div class="max-w-3xl mx-auto px-6 py-12 space-y-4">
                <h2 class="text-2xl font-bold mb-8">Photos of <%= selectedHome.homename %>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="col-span-1 md:col-span-2 aspect-[16/9] rounded-xl overflow-hidden bg-gray-100">
                        <img src="/images/img1.jpeg"
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                            alt="Home photo">
                    </div>
                    <div class="aspect-square rounded-xl overflow-hidden bg-gray-100">
                        <img src="/images/img2.jpeg"
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                            alt="Home photo">
