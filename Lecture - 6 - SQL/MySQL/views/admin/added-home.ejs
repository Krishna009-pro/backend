<%- include('../partials/head') %>

    <body class="bg-gray-50 flex flex-col min-h-screen">

        <!-- Header -->
        <header
            class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between shadow-sm sticky top-0 z-50">
            <div class="flex items-center gap-8">
                <a href="/" class="flex items-center gap-2">
                    <svg class="w-8 h-8 text-rose-500" viewBox="0 0 32 32" fill="currentColor">
                        <path
                            d="M16 1c2.008 0 3.463.963 4.751 3.269l.533 1.025c1.954 3.83 6.114 12.54 7.1 14.836l.145.346c1.264 3.033.864 5.922-1.121 8.125-1.921 2.132-4.634 3.321-7.558 3.404L19.4 32l-.35-.001h-.1c-3.134 0-5.967-1.354-7.85-3.649-1.884 2.295-4.717 3.649-7.85 3.649h-.1l-.35-.001C2.851 31.916.138 30.727-1.783 28.595c-1.985-2.203-2.385-5.092-1.121-8.125l.145-.346c.986-2.296 5.146-11.006 7.1-14.836l.533-1.025C6.537 1.963 7.992 1 10 1c2.008 0 3.463.963 4.751 3.269L16 6.538l1.249-2.269C18.537 1.963 19.992 1 22 1zm0 2c-1.282 0-2.19.643-3.142 2.345L11.59 18.27l-.145.346c-1.085 2.604-.844 4.814.646 6.468C13.298 26.46 15.111 27.228 17.152 27.32l.248.003h.1c2.613 0 4.858-1.214 6.167-3.235l.133-.21c.882-1.464 1.147-3.087.726-4.904l-.071-.248c-.066-.217-.184-.55-.353-.984l-.173-.42c-.933-2.19-4.809-10.435-6.732-14.21l-.533-1.025C18.19 2.643 17.282 2 16 2zm-6 0c-1.282 0-2.19.643-3.142 2.345L5.59 18.27l-.145.346c-1.085 2.604-.844 4.814.646 6.468C7.298 26.46 9.111 27.228 11.152 27.32l.248.003h.1c2.613 0 4.858-1.214 6.167-3.235l.133-.21c.882-1.464 1.147-3.087.726-4.904l-.071-.248c-.066-.217-.184-.55-.353-.984l-.173-.42c-.933-2.19-4.809-10.435-6.732-14.21l-.533-1.025C10.19 2.643 9.282 2 8 2z" />
                    </svg>
                    <span class="text-rose-500 font-bold text-xl tracking-tight">airbnb</span>
                </a>
                <%- include("../partials/nav") %>
            </div>
        </header>

        <main class="grow flex items-center justify-center p-6">
            <div
                class="max-w-md w-full bg-white rounded-3xl shadow-2xl p-10 text-center border border-gray-100 flex flex-col items-center">
                <!-- Success Icon -->
                <div class="mb-8 flex justify-center">
                    <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center animate-bounce">
                        <svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                </div>

                <h1 class="text-3xl font-bold text-gray-900 mb-4">Welcome Home!</h1>
                <p class="text-gray-500 mb-10 leading-relaxed">
                    Congratulations! Your home has been successfully listed. Travellers from around the world can now
                    discover your unique space.
                </p>

                <div class="space-y-4 w-full">
                    <a href="/"
                        class="block w-full bg-black text-white font-bold py-4 rounded-xl hover:bg-gray-800 transition-all shadow-lg text-lg text-center">
                        View My Listing
                    </a>
                    <a href="/admin/add-home"
                        class="block w-full bg-white text-gray-700 font-semibold py-4 rounded-xl border border-gray-300 hover:bg-gray-50 transition-all text-lg text-center">
                        Add Another Home
                    </a>
                </div>

                <p class="mt-8 text-sm text-gray-400">
                    Need help? Visit our <a href="#" class="underline hover:text-rose-500">Host Resource Centre</a>.
                </p>
            </div>
        </main>

    </body>

    </html>