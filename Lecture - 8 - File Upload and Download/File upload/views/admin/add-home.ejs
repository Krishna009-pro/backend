<%- include('../partials/head') %>

    <body class="bg-gray-50 flex flex-col min-h-screen">

        <!-- Header -->
        <header
            class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between shadow-sm sticky top-0 z-50">
            <div class="flex items-center gap-8">

                <%- include("../partials/nav") %>
            </div>
            <div class="flex items-center gap-4">
                <button
                    class="text-sm font-semibold py-2 px-4 hover:bg-gray-100 rounded-full transition-colors">Questions?</button>
                <button
                    class="border border-black text-sm font-semibold py-2 px-4 rounded-lg hover:bg-gray-100 transition-colors">Save
                    & exit</button>
            </div>
        </header>

        <!-- Main Content -->
        <main class="grow flex items-center justify-center p-6">
            <div class="max-w-xl w-full bg-white rounded-2xl shadow-xl p-8 md:p-12 border border-gray-100">
                <div class="mb-10 text-center">
                    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-2">
                        <% if (editing) { %>Edit Your Hosted <% } else { %>Host Your<% } %> Home
                    </h1>
                    <p class="text-gray-500">Fill in the details below to list your amazing place on Airbnb.</p>
                </div>

                <form action="/admin/<%= editing ? 'edit-home' : 'add-home'%>" method="POST"
                    enctype="multipart/form-data" class="space-y-6">
                    <input type="hidden" name="_id" value="<%= editing ? home._id : '' %>">
                    <!-- Home Name -->
                    <div>
                        <label for="homename" class="block text-sm font-semibold text-gray-700 mb-2">Home
                            Name</label>
                        <input type="text" id="homename" name="homename" value="<%= editing ? home.homename : ''%>"
                            placeholder="e.g. Modern Cliffside Villa" class="w-full px-4 py-3 border border-gray-300
                        rounded-lg focus:ring-2 focus:ring-rose-500
                        focus:border-rose-500 outline-none transition-all placeholder:text-gray-400" required>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Price -->
                        <div>
                            <label for="price" class="block text-sm font-semibold text-gray-700 mb-2">Price per
                                night
                                (₹)</label>
                            <input type="number" id="price" name="price" required placeholder="5000"
                                value="<%= editing ? home.price : ''%>"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all placeholder:text-gray-400">
                        </div>
                    </div>
                    <!-- Location & Rating -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="location"
                                class="block text-sm font-semibold text-gray-700 mb-2">Location</label>
                            <input type="text" id="location" name="location" required
                                value="<%= editing ? home.location : ''%>" placeholder="e.g. Mumbai, Maharashtra"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all placeholder:text-gray-400">
                        </div>
                        <div>
                            <label for="rating" class="block text-sm font-semibold text-gray-700 mb-2">Rating
                                (1-5)</label>
                            <input type="number" id="rating" name="rating" required step="0.01" min="0" max="5"
                                placeholder="e.g. 4.85" value="<%= editing ? home.rating : ''%>"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all placeholder:text-gray-400">
                        </div>
                    </div>

                    <!-- Image Upload (Multiple) -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <label class="block text-sm font-semibold text-gray-700">Property Images</label>
                            <span id="imageCount"
                                class="hidden text-xs font-medium px-3 py-1 bg-rose-100 text-rose-600 rounded-full">
                                0 images
                            </span>
                        </div>

                        <!-- Drop Zone -->
                        <div id="dropZone"
                            class="relative border-2 border-dashed border-gray-300 rounded-xl p-8 text-center transition-all duration-300 hover:border-rose-400 hover:bg-rose-50/50 cursor-pointer group">
                            <!-- Hidden File Input -->
                            <input type="file" id="image" name="image" class="hidden">

                            <!-- Upload Icon & Text (shown when no images) -->
                            <div id="uploadPlaceholder" class="space-y-3">
                                <!-- Upload Icon -->
                                <div
                                    class="mx-auto w-16 h-16 bg-gradient-to-br from-rose-100 to-pink-100 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                    <svg class="w-8 h-8 text-rose-500" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z">
                                        </path>
                                    </svg>
                                </div>

                                <!-- Instructions -->
                                <div>
                                    <p class="text-base font-semibold text-gray-700 mb-1">
                                        <span class="text-rose-500 hover:text-rose-600 transition-colors">Click to
                                            upload</span>
                                        <span class="text-gray-500">or drag and drop</span>
                                    </p>
                                    <p class="text-sm text-gray-500">PNG, JPG or JPEG • Multiple files allowed (MAX. 5MB
                                        each)</p>
                                </div>
                            </div>

                            <!-- Image Gallery Preview (hidden initially) -->
                            <div id="imageGallery" class="hidden">
                                <div id="imageGrid" class="grid grid-cols-2 md:grid-cols-3 gap-4"></div>
                                <!-- Add More Button -->
                                <button type="button" id="addMoreBtn"
                                    class="mt-4 px-4 py-2 border-2 border-dashed border-rose-300 rounded-lg hover:border-rose-500 hover:bg-rose-50 transition-all text-sm font-medium text-rose-600 flex items-center gap-2 mx-auto">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 4v16m8-8H4"></path>
                                    </svg>
                                    Add More Images
                                </button>
                            </div>
                        </div>

                        <p class="mt-2 text-xs text-gray-500 flex items-center gap-1">
                            <svg class="w-3.5 h-3.5 text-rose-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            Upload multiple high-quality images to showcase your property
                        </p>
                    </div>

                    <!-- JavaScript for Multiple Image Upload -->
                    <script>
                        const dropZone = document.getElementById('dropZone');
                        const fileInput = document.getElementById('image');
                        const uploadPlaceholder = document.getElementById('uploadPlaceholder');
                        const imageGallery = document.getElementById('imageGallery');
                        const imageGrid = document.getElementById('imageGrid');
                        const addMoreBtn = document.getElementById('addMoreBtn');
                        const imageCount = document.getElementById('imageCount');

                        let selectedFiles = new DataTransfer();

                        // Click to upload
                        dropZone.addEventListener('click', (e) => {
                            if (!e.target.closest('#imageGrid') && !e.target.closest('#addMoreBtn')) {
                                fileInput.click();
                            }
                        });

                        // Add more button
                        addMoreBtn.addEventListener('click', (e) => {
                            e.stopPropagation();
                            fileInput.click();
                        });

                        // File input change
                        fileInput.addEventListener('change', handleFileSelect);

                        // Drag and drop events
                        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                            dropZone.addEventListener(eventName, preventDefaults, false);
                        });

                        function preventDefaults(e) {
                            e.preventDefault();
                            e.stopPropagation();
                        }

                        ['dragenter', 'dragover'].forEach(eventName => {
                            dropZone.addEventListener(eventName, () => {
                                dropZone.classList.add('border-rose-500', 'bg-rose-100');
                            });
                        });

                        ['dragleave', 'drop'].forEach(eventName => {
                            dropZone.addEventListener(eventName, () => {
                                dropZone.classList.remove('border-rose-500', 'bg-rose-100');
                            });
                        });

                        dropZone.addEventListener('drop', (e) => {
                            const dt = e.dataTransfer;
                            const files = dt.files;
                            handleFiles(files);
                        });

                        function handleFileSelect() {
                            const files = fileInput.files;
                            handleFiles(files);
                        }

                        function handleFiles(files) {
                            const validTypes = ['image/jpeg', 'image/jpg', 'image/png'];
                            let hasInvalid = false;

                            Array.from(files).forEach(file => {
                                // Validate file type
                                // if (!validTypes.includes(file.type)) {
                                //     alert(`${file.name} is not a valid image file (PNG, JPG, or JPEG only)`);
                                //     hasInvalid = true;
                                //     return;
                                // }

                                // Validate file size (5MB)
                                if (file.size > 5 * 1024 * 1024) {
                                    alert(`${file.name} is too large. Maximum size is 5MB`);
                                    hasInvalid = true;
                                    return;
                                }

                                // Check if file already exists
                                const existingFiles = Array.from(selectedFiles.files);
                                if (!existingFiles.some(f => f.name === file.name && f.size === file.size)) {
                                    selectedFiles.items.add(file);
                                }
                            });

                            if (!hasInvalid && selectedFiles.files.length > 0) {
                                fileInput.files = selectedFiles.files;
                                displayImages();
                            }
                        }

                        function displayImages() {
                            imageGrid.innerHTML = '';
                            const files = Array.from(selectedFiles.files);

                            if (files.length === 0) {
                                uploadPlaceholder.classList.remove('hidden');
                                imageGallery.classList.add('hidden');
                                imageCount.classList.add('hidden');
                                return;
                            }

                            uploadPlaceholder.classList.add('hidden');
                            imageGallery.classList.remove('hidden');
                            imageCount.classList.remove('hidden');
                            imageCount.textContent = `${files.length} image${files.length > 1 ? 's' : ''}`;

                            files.forEach((file, index) => {
                                const reader = new FileReader();
                                reader.onload = (e) => {
                                    const imageCard = document.createElement('div');
                                    imageCard.className = 'relative group rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1';
                                    imageCard.innerHTML = `
                                        <img src="${e.target.result}" alt="${file.name}" 
                                            class="w-full h-40 object-cover">
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                                        <button type="button" 
                                            class="absolute top-2 right-2 bg-rose-500 hover:bg-rose-600 text-white rounded-full p-1.5 shadow-lg transform scale-0 group-hover:scale-100 transition-transform duration-300"
                                            onclick="removeImage(${index})">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                            </svg>
                                        </button>
                                        <div class="absolute bottom-0 left-0 right-0 p-2 bg-gradient-to-t from-black/80 to-transparent transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                                            <p class="text-white text-xs font-medium truncate">${file.name}</p>
                                            <p class="text-white/80 text-xs">${(file.size / 1024).toFixed(1)} KB</p>
                                        </div>
                                    `;
                                    imageGrid.appendChild(imageCard);
                                };
                                reader.readAsDataURL(file);
                            });
                        }

                        // Global function to remove image
                        window.removeImage = function (index) {
                            const dt = new DataTransfer();
                            const files = Array.from(selectedFiles.files);

                            files.forEach((file, i) => {
                                if (i !== index) {
                                    dt.items.add(file);
                                }
                            });

                            selectedFiles = dt;
                            fileInput.files = selectedFiles.files;
                            displayImages();
                        };
                    </script>
                    <!-- Description -->
                    <div>
                        <label for="description"
                            class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
                        <textarea id="description" name="description" rows="4"
                            placeholder="Describe your home, its features, and what makes it unique."
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all placeholder:text-gray-400"
                            required><%= editing ? home.description : '' %></textarea>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit"
                        class="w-full bg-rose-500 hover:bg-rose-600 text-white font-bold py-4 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all text-lg tracking-wide mt-4">
                        <%= editing ? "Edit" : "Add" ; %> Your Home
                    </button>
                </form>
            </div>
        </main>

        <!-- Footer -->
        <footer class="bg-white border-t border-gray-200 px-6 py-4 flex items-center justify-between mt-10">
            <div class="w-full bg-gray-200 rounded-full h-1.5 max-w-xs overflow-hidden">
                <div class="bg-black h-full w-3/4"></div>
            </div>
            <a href="/" class="text-sm font-semibold underline hover:text-rose-500">Back to Home</a>
        </footer>

    </body>

    </html>