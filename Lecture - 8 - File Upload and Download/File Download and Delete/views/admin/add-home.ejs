<%- include('../partials/head') %>

    <body class="bg-gradient-to-br from-gray-50 to-gray-100 h-screen overflow-hidden">

        <!-- Header -->
        <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between shadow-sm">
            <div class="flex items-center gap-8">
                <%- include("../partials/nav") %>
            </div>
            <div class="flex items-center gap-3">
                <button
                    class="text-sm font-semibold py-1.5 px-3 hover:bg-gray-100 rounded-full transition-colors">Questions?</button>
                <button
                    class="border border-black text-sm font-semibold py-1.5 px-3 rounded-lg hover:bg-gray-100 transition-colors">Save
                    & exit</button>
            </div>
        </header>

        <!-- Main Content - Full Viewport -->
        <main class="h-[calc(100vh-120px)] overflow-y-auto px-6 py-4">
            <div class="max-w-7xl mx-auto">
                <div class="mb-4 text-center">
                    <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight mb-1">
                        <% if (editing) { %>Edit Your Hosted <% } else { %>Host Your<% } %> Home
                    </h1>
                    <p class="text-sm text-gray-500">Fill in the details below to list your amazing place on Airbnb.</p>
                </div>

                <form action="/admin/<%= editing ? 'edit-home' : 'add-home'%>" method="POST"
                    enctype="multipart/form-data" class="bg-white rounded-2xl shadow-xl p-6 border border-gray-100">
                    <input type="hidden" name="_id" value="<%= editing ? home._id : '' %>">

                    <!-- Two Column Layout -->
                    <div class="grid grid-cols-2 gap-6">

                        <!-- Left Column -->
                        <div class="space-y-4">
                            <!-- Home Name -->
                            <div>
                                <label for="homename" class="block text-xs font-semibold text-gray-700 mb-1">Home
                                    Name</label>
                                <input type="text" id="homename" name="homename"
                                    value="<%= editing ? home.homename : ''%>" placeholder="e.g. Modern Cliffside Villa"
                                    class="w-full px-3 py-2 text-sm border border-gray-300
                                    rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all placeholder:text-gray-400"
                                    required>
                            </div>

                            <!-- Price & Rating -->
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label for="price"
                                        class="block text-xs font-semibold text-gray-700 mb-1">Price/night (₹)</label>
                                    <input type="number" id="price" name="price" required placeholder="5000"
                                        value="<%= editing ? home.price : ''%>"
                                        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
                                </div>
                                <div>
                                    <label for="rating" class="block text-xs font-semibold text-gray-700 mb-1">Rating
                                        (1-5)</label>
                                    <input type="number" id="rating" name="rating" required step="0.01" min="0" max="5"
                                        placeholder="4.85" value="<%= editing ? home.rating : ''%>"
                                        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
                                </div>
                            </div>

                            <!-- Location -->
                            <div>
                                <label for="location"
                                    class="block text-xs font-semibold text-gray-700 mb-1">Location</label>
                                <input type="text" id="location" name="location" required
                                    value="<%= editing ? home.location : ''%>" placeholder="e.g. Mumbai, Maharashtra"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all">
                            </div>

                            <!-- Description -->
                            <div>
                                <label for="description"
                                    class="block text-xs font-semibold text-gray-700 mb-1">Description</label>
                                <textarea id="description" name="description" rows="4"
                                    placeholder="Describe your home, its features, and what makes it unique."
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all placeholder:text-gray-400"
                                    required><%= editing ? home.description : '' %></textarea>
                            </div>

                            <!-- Home Rules PDF Upload -->
                            <div>
                                <div class="flex items-center justify-between mb-1">
                                    <label class="block text-xs font-semibold text-gray-700">Home Rules Document</label>
                                    <span id="rulesFileName"
                                        class="hidden text-xs font-medium px-2 py-0.5 bg-blue-100 text-blue-600 rounded-full text-[10px]">
                                        No file
                                    </span>
                                </div>

                                <div id="rulesDropZone"
                                    class="relative border-2 border-dashed border-gray-300 rounded-lg p-4 text-center transition-all duration-300 hover:border-blue-400 hover:bg-blue-50/50 cursor-pointer group">
                                    <input type="file" id="rulesFile" name="rulesFile" accept=".pdf,.doc,.docx"
                                        class="hidden">

                                    <div id="rulesUploadPlaceholder" class="space-y-2">
                                        <div
                                            class="mx-auto w-10 h-10 bg-gradient-to-br from-blue-100 to-indigo-100 rounded-full flex items-center justify-center">
                                            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                                                </path>
                                            </svg>
                                        </div>
                                        <p class="text-xs font-semibold text-gray-700">
                                            <span class="text-blue-500">Upload</span> PDF/DOC (Max 10MB)
                                        </p>
                                    </div>

                                    <div id="rulesFilePreview" class="hidden">
                                        <div
                                            class="flex items-center gap-3 p-2 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg border border-blue-200">
                                            <div
                                                class="flex-shrink-0 w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
                                                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z">
                                                    </path>
                                                </svg>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <p id="rulesFileNameText"
                                                    class="text-xs font-bold text-gray-800 truncate"></p>
                                                <p id="rulesFileSizeText" class="text-[10px] text-gray-600"></p>
                                            </div>
                                            <button type="button" id="removeRulesBtn"
                                                class="flex-shrink-0 p-1 bg-rose-500 hover:bg-rose-600 text-white rounded-lg transition-all">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column -->
                        <div class="space-y-4">
                            <!-- Property Images -->
                            <div>
                                <div class="flex items-center justify-between mb-1">
                                    <label class="block text-xs font-semibold text-gray-700">Property Images</label>
                                    <span id="imageCount"
                                        class="hidden text-xs font-medium px-2 py-0.5 bg-rose-100 text-rose-600 rounded-full text-[10px]">
                                        0 images
                                    </span>
                                </div>

                                <div id="dropZone"
                                    class="relative border-2 border-dashed border-gray-300 rounded-lg p-4 text-center transition-all duration-300 hover:border-rose-400 hover:bg-rose-50/50 cursor-pointer group h-[calc(100%-2rem)]">
                                    <input type="file" id="image" name="image" class="hidden">

                                    <div id="uploadPlaceholder" class="space-y-2">
                                        <div
                                            class="mx-auto w-12 h-12 bg-gradient-to-br from-rose-100 to-pink-100 rounded-full flex items-center justify-center">
                                            <svg class="w-6 h-6 text-rose-500" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z">
                                                </path>
                                            </svg>
                                        </div>
                                        <p class="text-xs font-semibold text-gray-700">
                                            <span class="text-rose-500">Click to upload</span>
                                            <span class="text-gray-500"> or drag</span>
                                        </p>
                                        <p class="text-[10px] text-gray-500">PNG, JPG (Max 5MB each)</p>
                                    </div>

                                    <div id="imageGallery" class="hidden max-h-[400px] overflow-y-auto">
                                        <div id="imageGrid" class="grid grid-cols-2 gap-2 mb-2"></div>
                                        <button type="button" id="addMoreBtn"
                                            class="px-3 py-1.5 border-2 border-dashed border-rose-300 rounded-lg hover:border-rose-500 hover:bg-rose-50 transition-all text-xs font-medium text-rose-600 flex items-center gap-2 mx-auto">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M12 4v16m8-8H4"></path>
                                            </svg>
                                            Add More
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Button - Full Width -->
                    <button type="submit"
                        class="w-full bg-gradient-to-r from-rose-500 to-pink-500 hover:from-rose-600 hover:to-pink-600 text-white font-bold py-3 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all text-base tracking-wide mt-6">
                        <%= editing ? "Update" : "Add" ; %> Your Home
                    </button>
                </form>
            </div>
        </main>

        <!-- Compact Footer -->
        <footer class="bg-white border-t border-gray-200 px-6 py-2 flex items-center justify-between">
            <div class="w-full bg-gray-200 rounded-full h-1 max-w-xs overflow-hidden">
                <div class="bg-rose-500 h-full w-3/4"></div>
            </div>
            <a href="/" class="text-xs font-semibold underline hover:text-rose-500">Back to Home</a>
        </footer>

        <!-- JavaScript for Image Upload -->
        <script>
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('image');
            const uploadPlaceholder = document.getElementById('uploadPlaceholder');
            const imageGallery = document.getElementById('imageGallery');
            const imageGrid = document.getElementById('imageGrid');
            const addMoreBtn = document.getElementById('addMoreBtn');
            const imageCount = document.getElementById('imageCount');

            let selectedFiles = new DataTransfer();

            dropZone.addEventListener('click', (e) => {
                if (!e.target.closest('#imageGrid') && !e.target.closest('#addMoreBtn')) {
                    fileInput.click();
                }
            });

            addMoreBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                fileInput.click();
            });

            fileInput.addEventListener('change', handleFileSelect);

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                dropZone.addEventListener(eventName, () => {
                    dropZone.classList.add('border-rose-500', 'bg-rose-100');
                });
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, () => {
                    dropZone.classList.remove('border-rose-500', 'bg-rose-100');
                });
            });

            dropZone.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                handleFiles(files);
            });

            function handleFileSelect() {
                const files = fileInput.files;
                handleFiles(files);
            }

            function handleFiles(files) {
                let hasInvalid = false;

                Array.from(files).forEach(file => {
                    if (file.size > 5 * 1024 * 1024) {
                        alert(`${file.name} is too large. Maximum size is 5MB`);
                        hasInvalid = true;
                        return;
                    }

                    const existingFiles = Array.from(selectedFiles.files);
                    if (!existingFiles.some(f => f.name === file.name && f.size === file.size)) {
                        selectedFiles.items.add(file);
                    }
                });

                if (!hasInvalid && selectedFiles.files.length > 0) {
                    fileInput.files = selectedFiles.files;
                    displayImages();
                }
            }

            function displayImages() {
                imageGrid.innerHTML = '';
                const files = Array.from(selectedFiles.files);

                if (files.length === 0) {
                    uploadPlaceholder.classList.remove('hidden');
                    imageGallery.classList.add('hidden');
                    imageCount.classList.add('hidden');
                    return;
                }

                uploadPlaceholder.classList.add('hidden');
                imageGallery.classList.remove('hidden');
                imageCount.classList.remove('hidden');
                imageCount.textContent = `${files.length} image${files.length > 1 ? 's' : ''}`;

                files.forEach((file, index) => {
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const imageCard = document.createElement('div');
                        imageCard.className = 'relative group rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-all';
                        imageCard.innerHTML = `
                            <img src="${e.target.result}" alt="${file.name}" class="w-full h-24 object-cover">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <button type="button" 
                                class="absolute top-1 right-1 bg-rose-500 hover:bg-rose-600 text-white rounded-full p-1 shadow-lg transform scale-0 group-hover:scale-100 transition-transform"
                                onclick="removeImage(${index})">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </button>
                            <div class="absolute bottom-0 left-0 right-0 p-1 bg-gradient-to-t from-black/80 to-transparent transform translate-y-full group-hover:translate-y-0 transition-transform">
                                <p class="text-white text-[10px] font-medium truncate">${file.name}</p>
                            </div>
                        `;
                        imageGrid.appendChild(imageCard);
                    };
                    reader.readAsDataURL(file);
                });
            }

            window.removeImage = function (index) {
                const dt = new DataTransfer();
                const files = Array.from(selectedFiles.files);

                files.forEach((file, i) => {
                    if (i !== index) {
                        dt.items.add(file);
                    }
                });

                selectedFiles = dt;
                fileInput.files = selectedFiles.files;
                displayImages();
            };
        </script>

        <!-- JavaScript for Rules File Upload -->
        <script>
            const rulesDropZone = document.getElementById('rulesDropZone');
            const rulesFileInput = document.getElementById('rulesFile');
            const rulesUploadPlaceholder = document.getElementById('rulesUploadPlaceholder');
            const rulesFilePreview = document.getElementById('rulesFilePreview');
            const rulesFileName = document.getElementById('rulesFileName');
            const rulesFileNameText = document.getElementById('rulesFileNameText');
            const rulesFileSizeText = document.getElementById('rulesFileSizeText');
            const removeRulesBtn = document.getElementById('removeRulesBtn');

            rulesDropZone.addEventListener('click', (e) => {
                if (!e.target.closest('#rulesFilePreview')) {
                    rulesFileInput.click();
                }
            });

            rulesFileInput.addEventListener('change', handleRulesFileSelect);

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                rulesDropZone.addEventListener(eventName, preventDefaultsRules, false);
            });

            function preventDefaultsRules(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                rulesDropZone.addEventListener(eventName, () => {
                    rulesDropZone.classList.add('border-blue-500', 'bg-blue-100');
                });
            });

            ['dragleave', 'drop'].forEach(eventName => {
                rulesDropZone.addEventListener(eventName, () => {
                    rulesDropZone.classList.remove('border-blue-500', 'bg-blue-100');
                });
            });

            rulesDropZone.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                if (files.length > 0) {
                    rulesFileInput.files = files;
                    handleRulesFileSelect();
                }
            });

            function handleRulesFileSelect() {
                const file = rulesFileInput.files[0];
                if (!file) return;

                const validTypes = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
                if (!validTypes.includes(file.type)) {
                    alert('Please upload a PDF or DOC file only');
                    rulesFileInput.value = '';
                    return;
                }

                if (file.size > 10 * 1024 * 1024) {
                    alert('File is too large. Maximum size is 10MB');
                    rulesFileInput.value = '';
                    return;
                }

                displayRulesFile(file);
            }

            function displayRulesFile(file) {
                rulesUploadPlaceholder.classList.add('hidden');
                rulesFilePreview.classList.remove('hidden');
                rulesFileName.classList.remove('hidden');

                rulesFileNameText.textContent = file.name;
                rulesFileSizeText.textContent = `${(file.size / 1024).toFixed(1)} KB`;
                rulesFileName.textContent = file.name.substring(0, 20) + '...';
            }

            removeRulesBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                rulesFileInput.value = '';
                rulesUploadPlaceholder.classList.remove('hidden');
                rulesFilePreview.classList.add('hidden');
                rulesFileName.classList.add('hidden');
                rulesFileName.textContent = 'No file';
            });
        </script>
    </body>

    </html>