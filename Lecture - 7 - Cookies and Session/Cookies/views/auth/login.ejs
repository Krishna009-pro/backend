<%- include('../partials/head') %>

    <body class="bg-white text-gray-900 font-sans selection:bg-rose-100 italic-none">

        <!-- Subtle Background Decoration -->
        <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
            <div
                class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-rose-50 rounded-full blur-[120px] opacity-60">
            </div>
            <div
                class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-blue-50 rounded-full blur-[120px] opacity-60">
            </div>
        </div>

        <!-- Header -->
        <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 px-6 py-4">
            <div class="max-w-7xl mx-auto flex items-center justify-between">

                <%- include("../partials/nav") %>
            </div>
        </header>

        <main class="flex min-h-[calc(100vh-80px)] items-center justify-center p-6">
            <div
                class="w-full max-w-[568px] bg-white rounded-2xl shadow-[0_8px_28px_rgba(0,0,0,0.12)] border border-gray-200 overflow-hidden animate-in fade-in zoom-in duration-500">
                <!-- Modal Header -->
                <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-center relative">
                    <a href="/" class="absolute left-6 hover:bg-gray-100 p-2 rounded-full transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </a>
                    <h2 class="font-bold text-base">Log in or sign up</h2>
                </div>

                <!-- Modal Content -->
                <div class="p-6">
                    <div class="mb-6">
                        <h3 class="text-2xl font-semibold text-gray-900 mb-2">Welcome to Airbnb</h3>
                        <p class="text-gray-500 text-sm">Experience the world with us.</p>
                    </div>

                    <form action="/auth/login" method="POST" class="space-y-4">
                        <!-- Auth Inputs Wrap -->
                        <div
                            class="rounded-xl border border-gray-400 overflow-hidden focus-within:ring-2 focus-within:ring-black focus-within:border-transparent transition-all">
                            <div class="relative px-4 py-3 border-b border-gray-400 group">
                                <label for="username"
                                    class="absolute top-2 left-4 text-[11px] font-medium text-gray-500 transition-all group-focus-within:text-black">Username
                                    or email</label>
                                <input type="text" id="username" name="username" required
                                    class="w-full mt-2 pt-1 text-base outline-none bg-transparent placeholder:text-transparent focus:placeholder:text-gray-400"
                                    placeholder="Username or email">
                            </div>
                            <div class="relative px-4 py-3 group">
                                <label for="password"
                                    class="absolute top-2 left-4 text-[11px] font-medium text-gray-500 transition-all group-focus-within:text-black">Password</label>
                                <input type="password" id="password" name="password" required
                                    class="w-full mt-2 pt-1 text-base outline-none bg-transparent placeholder:text-transparent focus:placeholder:text-gray-400"
                                    placeholder="••••••••">
                            </div>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="flex items-center justify-between px-1">
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="checkbox" name="remember"
                                    class="w-4 h-4 accent-rose-500 rounded border-gray-300 cursor-pointer">
                                <span
                                    class="text-xs font-semibold text-gray-600 group-hover:text-black transition-colors">Remember
                                    me</span>
                            </label>
                            <a href="#"
                                class="text-xs font-semibold underline hover:text-rose-500 transition-colors">Forgot
                                password?</a>
                        </div>

                        <!-- Login Button -->
                        <button type="submit"
                            class="w-full relative group overflow-hidden bg-rose-500 text-white font-bold py-3.5 rounded-lg transition-all active:scale-[0.98] shadow-lg shadow-rose-200">
                            <div
                                class="absolute inset-0 bg-linear-to-r from-rose-600 to-rose-400 opacity-0 group-hover:opacity-100 transition-opacity">
                            </div>
                            <span class="relative">Log in</span>
                        </button>
                    </form>

                    <!-- Divider -->
                    <div class="my-6 flex items-center gap-4 text-xs text-gray-400 uppercase font-bold tracking-widest">
                        <div class="h-px grow bg-gray-200"></div>
                        <span>or</span>
                        <div class="h-px grow bg-gray-200"></div>
                    </div>

                    <!-- Social Logins -->
                    <div class="flex items-center justify-center gap-6">
                        <!-- Google with colorful glow -->
                        <button
                            class="group relative p-4 bg-white rounded-full border-2 border-gray-100 transition-all duration-500 ease-out hover:border-red-100 hover:scale-[1.2] hover:-translate-y-2 hover:rotate-3 hover:shadow-[0_20px_40px_-10px_rgba(234,67,53,0.4)] hover:z-10">
                            <svg class="w-6 h-6 transition-transform duration-500 group-hover:rotate-[360deg]"
                                viewBox="0 0 48 48">
                                <path fill="#FFC107"
                                    d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24s8.955,20,20,20s20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z" />
                                <path fill="#FF3D00"
                                    d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z" />
                                <path fill="#4CAF50"
                                    d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z" />
                                <path fill="#1976D2"
                                    d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z" />
                            </svg>
                        </button>

                        <!-- Facebook with Blue Fill -->
                        <button
                            class="group relative p-4 bg-white rounded-full border-2 border-gray-100 transition-all duration-500 ease-out hover:border-[#1877F2] hover:bg-[#1877F2] hover:scale-[1.2] hover:-translate-y-2 hover:-rotate-3 hover:shadow-[0_20px_40px_-10px_rgba(24,119,242,0.5)] hover:z-10">
                            <svg class="w-6 h-6 text-[#1877F2] transition-colors duration-500 group-hover:text-white"
                                fill="currentColor" viewBox="0 0 24 24">
                                <path
                                    d="M12 2C6.477 2 2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.129 22 16.99 22 12c0-5.523-4.477-10-10-10z" />
                            </svg>
                        </button>

                        <!-- Apple with Dark Fill -->
                        <button
                            class="group relative p-4 bg-white rounded-full border-2 border-gray-100 transition-all duration-500 ease-out hover:border-black hover:bg-black hover:scale-[1.2] hover:-translate-y-2 hover:rotate-6 hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] hover:z-10">
                            <svg class="w-6 h-6 text-black transition-colors duration-500 group-hover:text-white"
                                fill="currentColor" viewBox="0 0 24 24">
                                <path
                                    d="M17.05 20.28c-.96.95-2.06 1.18-3.32 1.18-1.42 0-2.43-.45-3.31-.45-.9 0-2.05.45-3.37.45-1.5 0-2.73-.65-3.8-2.22-2.12-3.14-1.62-7.86.88-11.45 1.25-1.8 3.08-2.92 4.67-2.92.95 0 2.08.45 3.32.45.98 0 1.93-.45 3.3-.45 1.55 0 3.12 1.02 4.12 2.38-3.08 1.84-2.6 5.8 0 7.37-.88 2.22-2.05 4.38-3.49 5.71zm-4.32-15.63c-.08-2.5 1.9-4.65 4.38-4.65l.08.3c.08 2.5-1.92 4.65-4.38 4.65l-.08-.3z" />
                            </svg>
                        </button>
                    </div>

                    <div class="mt-8 text-center">
                        <p class="text-sm text-gray-600">
                            Don't have an account?
                            <a href="/auth/signup"
                                class="font-bold underline hover:text-rose-500 transition-colors">Sign up</a>
                        </p>
                    </div>
                </div>
            </div>
        </main>

        <!-- Footer Meta -->
        <footer class="max-w-7xl mx-auto px-6 py-8 text-xs text-center text-gray-400">
            <p>&copy; 2024 Airbnb, Inc. · <a href="#" class="hover:underline">Privacy</a> · <a href="#"
                    class="hover:underline">Terms</a> · <a href="#" class="hover:underline">Sitemap</a></p>
        </footer>

    </body>

    </html>